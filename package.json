{
  "name": "salta",
  "version": "0.1.0",
  "description": "Smart-home Abstraction and Local Transport Architecture",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/static": "^8.2.0",
    "@homebridge/hap-nodejs": "^1.1.2",
    "fastify": "^5.4.0",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "license": "MIT",
  "keywords": ["smart-home", "local-first", "homekit", "shelly", "openccu", "deconz"]
}

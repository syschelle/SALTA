{
  "name": "salta",
  "version": "0.6.0",
  "description": "SALTA local-first smart-home control plane",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@homebridge/hap-nodejs": "^2.1.9",
    "fastify": "^5.4.0",
    "pg": "^8.16.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "light-my-request": "^6.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "license": "Apache-2.0",
  "keywords": [
    "smart-home",
    "local-first",
    "homekit",
    "shelly",
    "zigbee",
    "phoscon",
    "deconz"
  ]
}
